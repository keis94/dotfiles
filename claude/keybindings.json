{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/ja/keybindings",
  "bindings": [
    {
      "context": "Chat",
      "bindings": {
        "ctrl+j": "chat:submit",
        "enter": "chat:newline"
      }
    },
    {
      "context": "Confirmation",
      "bindings": {
        "ctrl+j": "confirm:yes"
      }
    },
    {
      "context": "Select",
      "bindings": {
        "ctrl+j": "select:accept"
      }
    }
  ]
}
